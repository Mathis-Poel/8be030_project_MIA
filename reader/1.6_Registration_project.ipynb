    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.model_selection import learning_curve\n",
    "import registration as reg\n",
    "from IPython.display import display, clear_output\n",
    "\n",
    "def intentsity_based_registration():\n",
    "    \"\"\"function used to determine the affine registration,\n",
    "    by changing some functions with affine_cor and affine_mi it was possible to \n",
    "    test all the variations with the outcomes stated below.\"\"\"\n",
    "    I = plt.imread('../data/image_data/3_1_t1.tif')\n",
    "    Im = plt.imread('../data/image_data/3_1_t2.tif')\n",
    "    ### For affine normalized cross correlation\n",
    "    # t1 with t1_d gives improvement of 29.25% with  learing rate 0.001\n",
    "    # t1 with t2 gives improvemtent of 11.62% with learing rate 0.001\n",
    "    # for a learing rate of 0.0001 it gives 26.51% but with increasing.\n",
    "    # learning rate 0.0005 gives 25.83% with final of 87.37%\n",
    "    # the learing rate the improvement declines.\n",
    "    ### For affine mutual information\n",
    "    # t1 with t2 gives improvement of 12.49% with learing rate of 0.001\n",
    "    \n",
    "\n",
    "    # Needs 7 parameters [rot, scaling_x, scaling_y,\n",
    "    # shearing_x, shearing_y, translation_x, translation_y]\n",
    "\n",
    "    x = np.array([0., 1., 1.,0.,0.,0.,0.]) \n",
    "    \n",
    "    fun= lambda x: reg.affine_corr(I,Im, x ,return_transform=False)\n",
    "    mu = 0.0005 #learing rate, the same as in rigid\n",
    "    num_iter =200\n",
    "\n",
    "    iterations = np.arange(1, num_iter+1)\n",
    "    similarity = np.full((num_iter, 1), np.nan)\n",
    "\n",
    "    fig = plt.figure(figsize=(14,6))\n",
    "\n",
    "    # fixed and moving image, and parameters\n",
    "    ax1 = fig.add_subplot(121)\n",
    "\n",
    "    # fixed image\n",
    "    im1 = ax1.imshow(I)\n",
    "    # moving image\n",
    "    im2 = ax1.imshow(I, alpha=0.7)\n",
    "    # parameters\n",
    "    txt = ax1.text(0.3, 0.95,\n",
    "        np.array2string(x, precision=5, floatmode='fixed'),\n",
    "        bbox={'facecolor': 'white', 'alpha': 1, 'pad': 10},\n",
    "        transform=ax1.transAxes)\n",
    "\n",
    "    # 'learning' curve\n",
    "    ax2 = fig.add_subplot(122, xlim=(0, num_iter), ylim=(0, 1))\n",
    "\n",
    "    learning_curve, = ax2.plot(iterations, similarity, lw=2)\n",
    "    ax2.set_xlabel('Iteration')\n",
    "    ax2.set_ylabel('Similarity')\n",
    "    ax2.grid()\n",
    "    \n",
    "    # This part changes form the demo function\n",
    "    for k in np.arange(num_iter):\n",
    "\n",
    "        # gradient ascent\n",
    "        g = reg.ngradient(fun, x)\n",
    "        x += g*mu\n",
    "\n",
    "        # for visualization of the result\n",
    "        S, Im_t, _ = reg.affine_corr(I, Im, x, return_transform=True)\n",
    "\n",
    "        clear_output(wait = True)\n",
    "\n",
    "        # update moving image and parameters\n",
    "        im2.set_data(Im_t)\n",
    "        txt.set_text(np.array2string(x, precision=5, floatmode='fixed'))\n",
    "\n",
    "        # update 'learning' curve\n",
    "        similarity[k] = S\n",
    "        learning_curve.set_xdata(iterations[:k+1])\n",
    "        learning_curve.set_ydata(similarity[:k+1])\n",
    "        ax2.relim()\n",
    "        ax2.autoscale_view()\n",
    "        fig.canvas.draw()\n",
    "        display(fig)\n",
    "    initial_similarity = similarity[0][0] * 100\n",
    "    final_similarity = similarity[-1][0] * 100\n",
    "\n",
    "    print(f\"Initial similarity: {initial_similarity:.2f}%\")\n",
    "    print(f\"Final similarity: {final_similarity:.2f}%\")\n",
    "    print(f\"Improvement: {final_similarity - initial_similarity:.2f}%\")\n",
    "intentsity_based_registration()"
   ]
