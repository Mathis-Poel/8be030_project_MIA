    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import registration as reg\n",
    "import registration_util as util\n",
    "\n",
    "# PART 1: T1 -> T1 registration\n",
    "\n",
    "fixed_path = '../data/image_data/3_2_t1.tif'\n",
    "moving_path = '../data/image_data/3_2_t1_d.tif'\n",
    "\n",
    "# Load images\n",
    "I = plt.imread(fixed_path)\n",
    "Im = plt.imread(moving_path)\n",
    "\n",
    "# Select corresponding points manually\n",
    "# First click a point in the left image,\n",
    "# then the matching point in the right image\n",
    "X, Xm = util.cpselect(fixed_path, moving_path)\n",
    "\n",
    "# Convert to homogeneous coordinates\n",
    "Xh = util.c2h(X)\n",
    "Xmh = util.c2h(Xm)\n",
    "\n",
    "# Compute affine transformation\n",
    "T = reg.ls_affine(Xh, Xmh)\n",
    "\n",
    "print(\"Estimated affine transformation matrix:\")\n",
    "print(T)\n",
    "\n",
    "# Transform moving image\n",
    "Im_reg, Xt = reg.image_transform(Im, T)\n",
    "\n",
    "# Visualization\n",
    "fig = plt.figure(figsize=(15,5))\n",
    "\n",
    "ax1 = fig.add_subplot(131)\n",
    "ax1.imshow(I, cmap='gray')\n",
    "ax1.set_title('Fixed T1 image')\n",
    "\n",
    "ax2 = fig.add_subplot(132)\n",
    "ax2.imshow(Im, cmap='gray')\n",
    "ax2.set_title('Moving T1 image')\n",
    "\n",
    "ax3 = fig.add_subplot(133)\n",
    "ax3.imshow(I, cmap='gray')\n",
    "ax3.imshow(Im_reg, cmap='hot', alpha=0.5)\n",
    "ax3.set_title('Registered overlay')\n",
    "\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# PART 2: T1 -> T2 registration\n",
    "\n",
    "fixed_path = '../data/image_data/3_2_t1.tif'\n",
    "moving_path = '../data/image_data/3_2_t2.tif'\n",
    "\n",
    "# Load images\n",
    "I = plt.imread(fixed_path)\n",
    "Im = plt.imread(moving_path)\n",
    "\n",
    "# Select corresponding control points\n",
    "X, Xm = util.cpselect(fixed_path, moving_path)\n",
    "\n",
    "# Convert to homogeneous coordinates\n",
    "Xh = util.c2h(X)\n",
    "Xmh = util.c2h(Xm)\n",
    "\n",
    "# Compute affine transformation\n",
    "T = reg.ls_affine(Xh, Xmh)\n",
    "\n",
    "print(\"Estimated affine transformation matrix:\")\n",
    "print(T)\n",
    "\n",
    "# Apply transformation\n",
    "Im_reg, Xt = reg.image_transform(Im, T)\n",
    "\n",
    "# Visualization\n",
    "fig = plt.figure(figsize=(15,5))\n",
    "\n",
    "ax1 = fig.add_subplot(131)\n",
    "ax1.imshow(I, cmap='gray')\n",
    "ax1.set_title('Fixed T1 image')\n",
